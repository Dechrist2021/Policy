# Custom bootstrap that respects strata
class StratifiedBootstrapInference(BootstrapInference):
    def __init__(self, n_bootstrap_samples, strata):
        self.strata = strata
        super().__init__(n_bootstrap_samples=n_bootstrap_samples)
    
    def _get_bootstrap_weights(self, n):
        unique_strata = np.unique(self.strata)
        weights = np.zeros(n)
        for s in unique_strata:
            idx = np.where(self.strata == s)[0]
            strata_weights = np.random.multinomial(len(idx), [1/len(idx)]*len(idx), size=1)[0]
            weights[idx] = strata_weights
        return weights

# --- Fit with Stratified Bootstrap ---
