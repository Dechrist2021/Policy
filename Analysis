def calculate_emissions(df):
    """
    Estimates CO₂ reduction assuming:
    - 0.1 kg CO₂/minute/vehicle (EPA MOVES model)
    - Delay reduction occurs during stop-and-go traffic (2× baseline rate)
    """
    df['co2_reduction'] = (df['final_delay'] - df['sim_delay']) * 0.2 * df['vehicle_count']
    return df['co2_reduction'].sum() / 1000  # Convert kg to metric tons

