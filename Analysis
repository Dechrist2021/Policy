def summarize_policy(df, label):
    savings = (df['final_delay'] - df['sim_delay']).sum()
    cost = df['sim_toll'].sum() * toll_cost
    return {
        'Policy': label,
        'Delay Reduction (hours)': round(savings / 60, 1),
        'Net Savings ($)': round(savings * value_per_minute - cost, 2),
        'ROI': round((savings * value_per_minute) / cost, 2),
        'Toll Activations': df['sim_toll'].sum(),
        'Avg Reduction (min)': round(abs(df.loc[df['sim_toll'] == 1, 'cate'].mean()), 2)
    }

# Generate results
results = pd.DataFrame([
    summarize_policy(df_fixed, "Fixed Threshold"),
    summarize_policy(df_dynamic, "Dynamic Threshold"),
    summarize_policy(df_hybrid, f"Hybrid Policy (${optimal_thresh:.2f} threshold)")
])

print("\n=== Final Policy Comparison ===")
print(results.to_markdown(index=False))

