# Expanded emissions calculation with sensitivity analysis
def calculate_emissions(df, emission_factor=0.2, verbose=False):
    """
    Args:
        emission_factor: kg CO₂/minute/vehicle 
                        (0.1=freeflow, 0.2=congested, 0.3=severe gridlock)
    """
    df['co2_reduction'] = (df['final_delay'] - df['sim_delay']) * emission_factor * df['vehicle_count']
    total = df['co2_reduction'].sum() / 1000
    
    if verbose:
        print(f"Parameters: {len(df)} records, {df['vehicle_count'].mean():.1f} avg vehicles")
        print(f"Total reduction: {total:.1f} metric tons (at {emission_factor} kg/min/veh)")
    
    return total

# Sensitivity test
