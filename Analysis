def get_feature_names(preprocessor):
    """Extracts feature names after all transformations"""
    feature_names = []
    
    # Get names from each transformer
    for name, transformer, columns in preprocessor.transformers_:
        if name == 'num':
            # For numeric pipeline with splines
            num_features = preprocessor.named_transformers_['num'].named_steps['spline'].get_feature_names_out(columns)
            feature_names.extend(num_features)
        elif name == 'interact':
            # Interaction features keep original names
            feature_names.extend(columns)
        elif name == 'zone':
            # Zone dummies (passed through)
            feature_names.extend(columns)
        elif name == 'bin':
            # Binary features (passed through)
            feature_names.extend(columns)
    
    return feature_names

