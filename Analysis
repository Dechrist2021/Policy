def preprocess_for_causal_model(df, lags=[1, 3, 6]):
    df = df.copy()
    
    # 1. Convert and Clean
    df['zone_type'] = df['zone_type'].astype('category')
    df['is_peak'] = df['is_peak'].astype(int)
    df['is_weekend'] = df['is_weekend'].astype(int)
    
    # 2. Create spatial coordinates from zone_id
    df[['x', 'y']] = df['zone_id'].str.extract(r'Z(\d+)_(\d+)').astype(int)
    
    # 3. Lagged Features
    for lag in lags:
        df[f'final_delay_lag_{lag}'] = df.groupby('zone_id')['final_delay'].shift(lag)
        df[f'vehicle_count_lag_{lag}'] = df.groupby('zone_id')['vehicle_count'].shift(lag)
        df[f'base_delay_lag_{lag}'] = df.groupby('zone_id')['base_delay'].shift(lag)
    
    # 4. Drop Missing
    essential_cols = ['toll_active', 'final_delay'] + [f'final_delay_lag_{lag}' for lag in lags]
    df = df.dropna(subset=essential_cols)
    
    # 5. Feature Engineering
    zone_dummies = pd.get_dummies(df['zone_type'], prefix='zone', drop_first=True)
    df = pd.concat([df, zone_dummies], axis=1)
    
    # Interactions
    for col in zone_dummies.columns:
        df[f'{col}_x_peak'] = zone_dummies[col] * df['is_peak']
        df[f'{col}_x_weekend'] = zone_dummies[col] * df['is_weekend']
        df[f'{col}_x_rain'] = zone_dummies[col] * df['rain']
    
    # Optional: Interactions with road quality
    df['road_quality_x_peak'] = df['road_quality'] * df['is_peak']
    df['road_quality_x_weekend'] = df['road_quality'] * df['is_weekend']
    
    # 6. Confounder Selection
    confounders = [
        'vehicle_count',
        'base_delay',
        'hour',
        'is_peak',
        'is_weekend',
        'rain',
        'event',
        'x', 'y',
        'road_quality'
    ] + [f'final_delay_lag_{lag}' for lag in lags] \
      + [f'vehicle_count_lag_{lag}' for lag in lags] \
      + [f'base_delay_lag_{lag}' for lag in lags] \
      + list(zone_dummies.columns) \
      + [f'{col}_x_peak' for col in zone_dummies.columns] \
      + [f'{col}_x_weekend' for col in zone_dummies.columns] \
      + [f'{col}_x_rain' for col in zone_dummies.columns] \
      + ['road_quality_x_peak', 'road_quality_x_weekend']

    # 7. Preprocessing Pipeline
    from sklearn.pipeline import Pipeline
    from sklearn.preprocessing import SplineTransformer, StandardScaler
    from sklearn.compose import ColumnTransformer
    
    numeric_features = [
        'vehicle_count', 
        'base_delay',
        'hour',
        'x', 'y',
        'road_quality'
    ] + [f'final_delay_lag_{lag}' for lag in lags] \
      + [f'vehicle_count_lag_{lag}' for lag in lags] \
      + [f'base_delay_lag_{lag}' for lag in lags]
    
    interaction_features = [
        f'{col}_x_peak' for col in zone_dummies.columns
    ] + [
        f'{col}_x_weekend' for col in zone_dummies.columns
    ] + [
        f'{col}_x_rain' for col in zone_dummies.columns
    ] + [
        'road_quality_x_peak',
        'road_quality_x_weekend'
    ]
    
    binary_features = ['is_peak', 'is_weekend', 'rain', 'event']
    zone_features = list(zone_dummies.columns)
    
    numeric_pipeline = Pipeline([
        ('spline', SplineTransformer(n_knots=4, degree=2)),
        ('scaler', StandardScaler())
    ])
    
    preprocessor = ColumnTransformer([
        ('num', numeric_pipeline, numeric_features),
        ('interact', StandardScaler(), interaction_features),
        ('zone', 'passthrough', zone_features),
        ('bin', 'passthrough', binary_features)
    ], remainder='drop')
    
    # 8. Final Output
    X = preprocessor.fit_transform(df[confounders])
    Y = df['final_delay'].values
    T = df['toll_active'].values
    
    return X, Y, T, preprocessor, df
X, Y, T, preprocessor, df_processed = preprocess_for_causal_model(urban_mobility_data)
