# Key Economic Parameters
value_per_minute = 0.10  # USD per minute of reduced delay
toll_cost = 0.08         # USD per toll activation
max_activations = 15000  # Budget constraint

# --------------------------------------------------
# 1. FIXED THRESHOLD POLICY (Top 25% most effective)
# --------------------------------------------------
fixed_threshold = df_sampled['cate'].quantile(0.25)
df_fixed = df_sampled.copy()
df_fixed['sim_toll'] = (df_fixed['cate'] <= fixed_threshold).astype(int)
df_fixed['sim_delay'] = df_fixed['final_delay'] + df_fixed['cate'] * df_fixed['sim_toll']

# --------------------------------------------------
# 2. DYNAMIC THRESHOLD POLICY (Economic viability)
# --------------------------------------------------
df_dynamic = df_sampled.copy()
df_dynamic['expected_savings'] = abs(df_dynamic['cate']) * value_per_minute
df_dynamic['sim_toll'] = (df_dynamic['expected_savings'] > 0.15).astype(int)
df_dynamic['sim_delay'] = df_dynamic['final_delay'] + df_dynamic['cate'] * df_dynamic['sim_toll']

if df_dynamic['sim_toll'].sum() > max_activations:
    threshold = df_dynamic['expected_savings'].nlargest(max_activations).min()
    df_dynamic['sim_toll'] = (df_dynamic['expected_savings'] >= threshold).astype(int)

# --------------------------------------------------
# 3. HYBRID POLICY WITH SENSITIVITY ANALYSIS
# --------------------------------------------------
print("\n=== Hybrid Policy Threshold Sensitivity Analysis ===")
threshold_results = []

for dynamic_thresh in [0.10, 0.12, 0.15]:
    df_hybrid = df_sampled.copy()
    
    # Stage 1: Dynamic threshold
    df_hybrid['expected_savings'] = abs(df_hybrid['cate']) * value_per_minute
    df_hybrid['sim_toll'] = (df_hybrid['expected_savings'] > dynamic_thresh).astype(int)
    
    # Stage 2: Fill remaining budget
    remaining = max_activations - df_hybrid['sim_toll'].sum()
    if remaining > 0:
        candidates = df_hybrid[df_hybrid['sim_toll'] == 0].nsmallest(remaining, 'cate')
        df_hybrid.loc[candidates.index, 'sim_toll'] = 1
    
    # Calculate metrics
    df_hybrid['sim_delay'] = df_hybrid['final_delay'] + df_hybrid['cate'] * df_hybrid['sim_toll']
    savings = (df_hybrid['final_delay'] - df_hybrid['sim_delay']).sum()
    cost = df_hybrid['sim_toll'].sum() * toll_cost
    roi = (savings * value_per_minute) / cost
    hours = savings / 60
    
    # Store results
    threshold_results.append({
        'Threshold': dynamic_thresh,
        'ROI': round(roi, 2),
        'Delay Reduction (hours)': round(hours, 1),
        'Activations': df_hybrid['sim_toll'].sum(),
        'Avg Effect (min)': round(abs(df_hybrid.loc[df_hybrid['sim_toll'] == 1, 'cate'].mean()), 2)
    })
    
    print(f"Threshold ${dynamic_thresh:.2f}: ROI={roi:.2f} | Reduction={hours:.1f}h | Activations={df_hybrid['sim_toll'].sum()}")

# Select optimal threshold (0.12 in this case)
optimal_thresh = 0.12
df_hybrid = df_sampled.copy()
df_hybrid['expected_savings'] = abs(df_hybrid['cate']) * value_per_minute
df_hybrid['sim_toll'] = (df_hybrid['expected_savings'] > optimal_thresh).astype(int)

