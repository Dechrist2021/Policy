def quota_hybrid_policy(df, quotas, dynamic_thresh=0.12):
    """
    Args:
        df: Input DataFrame with CATE and zone_type
        quotas: Dict of minimum activations per zone type (e.g., {'residential':0.2})
        dynamic_thresh: Economic savings threshold ($/minute)
    Returns:
        Policy DataFrame with quota-enforced toll activations
    """
    df = df.copy()
    df['expected_savings'] = abs(df['cate']) * value_per_minute
    
    # Stage 1: Dynamic threshold activation
    dynamic_mask = df['expected_savings'] > dynamic_thresh
    df['sim_toll'] = dynamic_mask.astype(int)
    
    # Stage 2: Quota fulfillment
    remaining_budget = max_activations - df['sim_toll'].sum()
    
    for zone_type, min_frac in quotas.items():
        zone_mask = (df['zone_type'] == zone_type) & (df['sim_toll'] == 0)
        required = int(min_frac * max_activations) - df[df['zone_type'] == zone_type]['sim_toll'].sum()
        
        if required > 0:
            candidates = df[zone_mask].nsmallest(required, 'cate')
            df.loc[candidates.index, 'sim_toll'] = 1
            remaining_budget -= len(candidates)
    
    # Stage 3: Fill remaining budget with highest-ROI zones
    if remaining_budget > 0:
        candidates = df[df['sim_toll'] == 0].nsmallest(remaining_budget, 'cate')
        df.loc[candidates.index, 'sim_toll'] = 1
    
    df['sim_delay'] = df['final_delay'] + df['cate'] * df['sim_toll']
    return df

